# Local development example

# Web service / apps/web
NEXT_PUBLIC_APP_NAME=Workforce Intelligence & Execution OS
NEXT_PUBLIC_API_URL=/api/v1
# Production static export / Railway web — use hardened API host:
# NEXT_PUBLIC_API_URL=https://hrmonitoringsystem-production-cb42.up.railway.app/api/v1
API_PROXY_URL=http://localhost:8080/api/v1

# API service / apps/api
# PostgreSQL must use UTF8 encoding for emoji/unicode messages.
# Example: CREATE DATABASE your_db WITH ENCODING 'UTF8' TEMPLATE template0 LC_COLLATE='C' LC_CTYPE='C';
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
APP_SECRET_KEY=change-me-locally
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# Auth rate limits (optional overrides)
# AUTH_LOGIN_MAX_ATTEMPTS=5
# AUTH_LOGIN_WINDOW_SECONDS=900
# AUTH_FORGOT_PASSWORD_MAX_ATTEMPTS=3
# AUTH_FORGOT_PASSWORD_WINDOW_SECONDS=900
# AUTH_RESET_PASSWORD_MAX_ATTEMPTS=5
# AUTH_RESET_PASSWORD_WINDOW_SECONDS=900
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/workforce_intelligence_utf8
DATABASE_PUBLIC_URL=
PGDATABASE=workforce_intelligence_utf8
PGHOST=localhost
PGPASSWORD=postgres
PGPORT=5432
PGUSER=postgres
REDIS_URL=redis://localhost:6379/0
FRONTEND_BASE_URL=http://localhost:3002
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3002

# Email, optional locally
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
EMAILS_FROM_NAME="Workforce OS"

# Bootstrap
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-this-password
BOOTSTRAP_ADMIN_NAME="HR Admin"

# Profile picture storage (local dev; use durable storage/volume in production)
PROFILE_IMAGE_STORAGE=local
PROFILE_IMAGE_UPLOAD_DIR=storage/profile-pictures
PROFILE_IMAGE_PUBLIC_BASE_URL=
