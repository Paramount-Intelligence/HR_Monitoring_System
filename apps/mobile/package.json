{
  "name": "mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@tanstack/query-async-storage-persister": "^5.101.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "axios": "^1.17.0",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.0",
    "expo-application": "~7.0.8",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-webrtc": "^124.0.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@config-plugins/react-native-webrtc": "^13.0.0",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "export:android": "expo export --platform android",
    "export:ios": "expo export --platform ios",
    "eas:whoami": "npx eas-cli whoami",
    "eas:configure": "npx eas-cli build:configure",
    "eas:build:dev": "npx eas-cli build --platform android --profile development --non-interactive",
    "eas:build:preview": "npx eas-cli build --platform android --profile preview --non-interactive",
    "eas:build:production": "npx eas-cli build --platform android --profile production --non-interactive",
    "eas:build:ios-simulator": "npx eas-cli build --platform ios --profile ios-simulator --non-interactive",
    "eas:build:ios-preview": "npx eas-cli build --platform ios --profile preview --non-interactive",
    "eas:build:ios-production": "npx eas-cli build --platform ios --profile production --non-interactive",
    "eas:credentials": "npx eas-cli credentials -p android",
    "eas:credentials:ios": "npx eas-cli credentials -p ios",
    "eas:submit:production": "npx eas-cli submit --platform android --profile production --non-interactive",
    "eas:submit:ios-production": "npx eas-cli submit --platform ios --profile production --non-interactive"
  },
  "private": true,
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "expo": {
    "install": {
      "exclude": [
        "typescript"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-webrtc"
        ]
      }
    }
  }
}
