# Web service / apps/web — local development

NEXT_PUBLIC_APP_NAME=Workforce Intelligence & Execution OS

# Browser API base. Local dev uses same-origin proxy via next.config rewrites.
NEXT_PUBLIC_API_URL=/api/v1

# Dev-only proxy target (not used in production builds)
API_PROXY_URL=http://localhost:8080/api/v1

# Optional locally — derive from NEXT_PUBLIC_API_URL when using absolute API URL in production
# NEXT_PUBLIC_WS_URL=ws://localhost:8080/api/v1/ws

APP_ENV=development

# Production Railway web service (set at build time):
# NEXT_PUBLIC_API_URL=https://<your-api-service>.up.railway.app/api/v1
# NEXT_PUBLIC_WS_URL=wss://<your-api-service>.up.railway.app/api/v1/ws
# APP_ENV=production

# Not required — public VAPID key is fetched from GET /api/v1/notifications/push-public-key
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
