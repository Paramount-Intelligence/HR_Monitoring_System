# API service / apps/api — local development

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
APP_SECRET_KEY=change-me-locally
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/workforce_intelligence_utf8
REDIS_URL=redis://localhost:6379/0

FRONTEND_BASE_URL=http://localhost:3002
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://127.0.0.1:3000

# Bootstrap (local only)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-this-password
BOOTSTRAP_ADMIN_NAME=HR Admin

# Email (optional locally)
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
EMAILS_FROM_NAME=Workforce OS

# Web Push (optional — API service only)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com

# Production Railway API (see infra/RAILWAY_ENV.md):
# APP_ENV=production
# APP_SECRET_KEY=<generated-long-random-secret>
# FRONTEND_BASE_URL=https://pimsmonitoringsystem.up.railway.app
# CORS_ORIGINS=https://pimsmonitoringsystem.up.railway.app
